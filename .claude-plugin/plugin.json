{
  "name": "pordee-pen-caveman",
  "description": "Auto Thai/English terse mode for Claude Code. Detects prompt language and injects pordee (Thai) or caveman (English) rules per turn. Cuts ~60-75% of output tokens while keeping technical accuracy.",
  "author": {
    "name": "Vatunyoo Suwannapisit"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/pordee-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading pordee-pen-caveman..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/lang-auto-switch.js\"",
            "timeout": 5,
            "statusMessage": "Detecting language..."
          }
        ]
      }
    ]
  }
}
