<!--
  Append these dllmap entries inside the <configuration> element of
  /etc/mono/config (just before the closing </configuration>).

  They redirect P/Invoke calls into "kernel32" / "kernel32.dll" to the no-op
  libkernel32.so stub (built from libkernel32.c), which provides
  SetConsoleCtrlHandler so the Road server's console loop does not crash on
  Linux/Mono.
-->
<dllmap dll="kernel32" target="libkernel32.so" os="!windows"/>
<dllmap dll="kernel32.dll" target="libkernel32.so" os="!windows"/>
